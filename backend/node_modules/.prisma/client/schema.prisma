generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Local {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String?
  m2        Float
  m2Terraza Float? // null = no tiene terraza
  categoria String // PISO_1 | PISO_2 | MERCADITO
  estado    String   @default("activo") // activo | vacio | inactivo
  piso      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contratos    Contrato[]
  lecturasLuz  LecturaLuz[]
  lecturasAgua LecturaAgua[]
  facturas     Factura[]
  multas       Multa[]
}

model Arrendatario {
  id              String   @id @default(cuid())
  rut             String   @unique
  razonSocial     String
  nombreComercial String?
  giro            String?
  email           String?
  emailSecundario String?
  telefono        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contratos Contrato[]
  usuario   Usuario?
}

model Contrato {
  id                 String    @id @default(cuid())
  localId            String
  arrendatarioId     String
  ufM2Arriendo       Float
  ufM2Gc             Float
  ufM2Terraza        Float?
  ufM2GcTerraza      Float?
  fondoPromo         Float?
  precioFijoArriendo Float?
  precioFijoGc       Float?
  vigenciaDesde      DateTime
  vigenciaHasta      DateTime?
  descuentosJson     Json?
  activo             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  local        Local        @relation(fields: [localId], references: [id])
  arrendatario Arrendatario @relation(fields: [arrendatarioId], references: [id])
}

model Tarifa {
  id             String   @id @default(cuid())
  mes            String   @unique // YYYY-MM
  valorUf        Float
  iva            Float    @default(0.19)
  precioKwh      Float
  precioM3Agua   Float
  toleranciaPago Float    @default(1000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TarifaCategoria {
  id            String    @id @default(cuid())
  categoria     String
  ufM2Arriendo  Float
  ufM2Gc        Float
  vigenciaDesde DateTime
  vigenciaHasta DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([categoria, vigenciaDesde])
}

model LecturaLuz {
  id              String   @id @default(cuid())
  localId         String
  mes             String // YYYY-MM
  lecturaAnterior Float
  lecturaActual   Float
  kwh             Float
  fuente          String   @default("excel") // excel | manual
  anomalia        Boolean  @default(false)
  createdAt       DateTime @default(now())

  local Local @relation(fields: [localId], references: [id])

  @@unique([localId, mes])
}

model LecturaAgua {
  id              String   @id @default(cuid())
  localId         String
  mes             String // YYYY-MM
  lecturaAnterior Float?
  lecturaActual   Float?
  m3              Float?
  costoTotal      Float? // importe directo desde Excel de facturación (Agua_$)
  fuente          String   @default("manual") // manual | excel | facturacion
  anomalia        Boolean  @default(false)
  createdAt       DateTime @default(now())

  local Local @relation(fields: [localId], references: [id])

  @@unique([localId, mes])
}

model Factura {
  id               String    @id @default(cuid())
  localId          String
  mes              String // YYYY-MM
  contratoSnapshot Json
  itemsJson        Json
  subtotal         Float
  iva              Float
  total            Float
  saldoAnterior    Float     @default(0)
  estado           String    @default("borrador")
  // borrador | emitida | enviada | parcial | pagada | vencida | mora | recuperada | anulada
  pdfUrl           String?
  folio            String?   @unique
  generadaAt       DateTime?
  enviadaAt        DateTime?
  vencimiento      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  local   Local           @relation(fields: [localId], references: [id])
  eventos FacturaEvento[]
  pagos   Pago[]
}

model FacturaEvento {
  id        String   @id @default(cuid())
  facturaId String
  tipo      String // generada | enviada | pago_parcial | pagada | vencida | anulada | comentario
  payload   Json?
  actor     String
  at        DateTime @default(now())

  factura Factura @relation(fields: [facturaId], references: [id])
}

model Multa {
  id          String   @id @default(cuid())
  localId     String
  mes         String
  motivo      String
  monto       Float
  aprobadaPor String
  aplicada    Boolean  @default(false)
  createdAt   DateTime @default(now())

  local Local @relation(fields: [localId], references: [id])
}

model Comprobante {
  id               String    @id @default(cuid())
  fuenteEmail      String?
  rawAttachmentUrl String?
  ocrJson          Json?
  rutDetectado     String?
  montoDetectado   Float?
  fechaDetectada   DateTime?
  estado           String    @default("pendiente") // pendiente | conciliado | rechazado
  recibidoAt       DateTime  @default(now())

  pagos Pago[]
}

model Pago {
  id            String    @id @default(cuid())
  facturaId     String
  comprobanteId String?
  monto         Float
  modoMatch     String    @default("manual") // exacto | tolerancia | manual
  conciliadoAt  DateTime?
  conciliadoPor String?
  createdAt     DateTime  @default(now())

  factura     Factura      @relation(fields: [facturaId], references: [id])
  comprobante Comprobante? @relation(fields: [comprobanteId], references: [id])
}

model Usuario {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  nombre         String
  rol            String // admin | tenant | board
  arrendatarioId String?  @unique
  localId        String?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  arrendatario Arrendatario? @relation(fields: [arrendatarioId], references: [id])
}

model Auditoria {
  id          String   @id @default(cuid())
  actor       String
  rol         String
  accion      String
  recurso     String
  recursoId   String?
  antesJson   Json?
  despuesJson Json?
  at          DateTime @default(now())
}
